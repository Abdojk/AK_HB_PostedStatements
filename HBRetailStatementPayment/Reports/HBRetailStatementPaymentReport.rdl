        <ConnectString>DynamicsAXDP</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>DynamicsAXDP</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="HBRetailStatementPaymentTmp">
      <Query>
