            <TablixColumnHierarchy>
              <TablixMembers>
                <TablixMember />
                <TablixMember />
                <TablixMember />
              </TablixMembers>
            </TablixColumnHierarchy>
            <TablixRowHierarchy>
              <TablixMembers>
                <!-- Store Group -->
                <TablixMember>
                  <Group Name="StoreGroup">
                    <GroupExpressions>
                      <GroupExpression>=Fields!StoreId.Value</GroupExpression>
                    </GroupExpressions>
                  </Group>
                  <SortExpressions>
                    <SortExpression>
                      <Value>=Fields!StoreId.Value</Value>
                    </SortExpression>
                  </SortExpressions>
                  <TablixMembers>
                    <!-- Store Group Header -->
                    <TablixMember>
                      <KeepWithGroup>After</KeepWithGroup>
                    </TablixMember>
                    <!-- Column Headers (static, repeats per store) -->
                    <TablixMember>
                      <KeepWithGroup>After</KeepWithGroup>
                    </TablixMember>
                    <!-- Detail Rows -->
                    <TablixMember>
                      <Group Name="DetailGroup">
                        <GroupExpressions>
                          <GroupExpression>=Fields!TenderTypeName.Value &amp; Fields!CurrencyCode.Value</GroupExpression>
                        </GroupExpressions>
                      </Group>
                      <SortExpressions>
                        <SortExpression>
                          <Value>=Fields!TenderTypeName.Value</Value>
                        </SortExpression>
                        <SortExpression>
                          <Value>=Fields!CurrencyCode.Value</Value>
                        </SortExpression>
                      </SortExpressions>
                    </TablixMember>
                    <!-- Store Subtotal -->
                    <TablixMember>
                      <KeepWithGroup>Before</KeepWithGroup>
                    </TablixMember>
                  </TablixMembers>
                </TablixMember>
                <!-- Grand Total (outside store group) -->
                <TablixMember>
                  <KeepWithGroup>Before</KeepWithGroup>
                </TablixMember>
              </TablixMembers>
            </TablixRowHierarchy>
